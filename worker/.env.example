# Copie este arquivo para .env e preencha os valores

# Banco de dados Neon (mesmo do app principal)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Groq API Key (já está no Doppler, só copiar)
GROQ_API_KEY=gsk_...

# Segredo compartilhado entre o frontend (Vercel) e o worker (Railway)
# Gere com: openssl rand -hex 32
WORKER_SECRET=seu_segredo_aqui

# Porta do servidor (Railway define automaticamente)
PORT=3001
