# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Banco de dados Neon (mesmo do app principal — cole do .env.local)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Groq API Key (gratuito em console.groq.com)
GROQ_API_KEY=gsk_...

# Segredo compartilhado entre o frontend e o worker
WORKER_SECRET=meu-segredo-local

# Porta do servidor
PORT=3001

# ── Limites de crawl para testes locais ───────────────────────────────────────

# Máximo de páginas de listagem (0 = sem limite)
CRAWL_MAX_PAGES=5

# Máximo de imóveis a enriquecer (0 = todos)
CRAWL_MAX_ENRICH=10

# Páginas de listagem em paralelo (discovery)
CRAWL_PAGE_CONCURRENCY=5

# Imóveis em paralelo no enriquecimento
CRAWL_CONCURRENCY=3
